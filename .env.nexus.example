# ── EvoNexus Configuration — TEMPLATE (copie para .env.nexus e preencha) ────

# Dashboard
EVONEXUS_SECRET_KEY=<gerar com: python3 -c "import secrets; print(secrets.token_hex(32))">
EVONEXUS_PORT=8080

# ── Dashboard API Token (para agentes headless / CLI) ──
DASHBOARD_API_TOKEN=<gerar com: python3 -c "import secrets; print(secrets.token_hex(32))">

# ── CRM integration ──
EVO_CRM_API_TOKEN=<UUID do token do Chatwoot>

# ── Evolution API integration ──
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=<apikey da Evolution API>

# ── LLM / AI Providers ──
# Anthropic (Claude) — opcional; sistema usa fallback automático quando vazio
ANTHROPIC_API_KEY=

# OpenAI direto (provider principal — gpt-4o-mini)
OPENAI_API_KEY=<sk-proj-...>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CLAUDE_CODE_USE_OPENAI=1

# OpenRouter (fallback automático quando OpenAI falha)
OPENROUTER_API_KEY=<sk-or-v1-...>
